DJANGO_SECRET_KEY=여기에-랜덤-비밀키-입력
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

GITHUB_API_TOKEN=put-your-github-token-here

# OpenAI API
# 가능한 모델 예시:
# gpt-4.1-mini  -> 현재 기본 추천, 비용/성능 균형
# gpt-4.1       -> 더 높은 품질
# gpt-4o-mini   -> 더 저렴하고 빠름
# gpt-4o        -> 범용 고품질
# gpt-4         -> 구형 모델, 가능하면 최신 계열 권장
OPENAI_API_KEY=put-your-openai-api-key-here
OPENAI_PROFILE_MODEL=gpt-4.1-mini
OPENAI_JOB_MODEL=gpt-4.1-mini

# GitHub
GITHUB_API_TOKEN=ghp_...

# OpenAI API
# 가능한 모델 예시:
# gpt-4.1-mini  -> 현재 기본 추천, 비용/성능 균형
# gpt-4.1       -> 더 높은 품질
# gpt-4o-mini   -> 더 저렴하고 빠름
# gpt-4o        -> 범용 고품질
OPENAI_API_KEY=sk-proj-...
OPENAI_PROFILE_MODEL=gpt-4.1-mini
OPENAI_JOB_MODEL=gpt-4.1-mini

# Jobs sync policy
JOB_ACTIVE_LIMIT_PER_SOURCE=300
JOB_ACTIVE_SOURCES=saramin,wanted
