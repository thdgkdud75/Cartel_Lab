DJANGO_SECRET_KEY=여기에-랜덤-비밀키-입력
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Database (Docker 환경에서는 DB_HOST=db)
DB_ENGINE=django.db.backends.mysql
DB_NAME=cartel_lab
DB_USER=root
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=3306

# GitHub
GITHUB_API_TOKEN=ghp_...
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/users/github/callback/

# OpenAI API
# 가능한 모델 예시:
# gpt-4.1-mini  -> 현재 기본 추천, 비용/성능 균형
# gpt-4.1       -> 더 높은 품질
# gpt-4o-mini   -> 더 저렴하고 빠름
# gpt-4o        -> 범용 고품질
OPENAI_API_KEY=sk-proj-...
OPENAI_PROFILE_MODEL=gpt-4.1-mini
OPENAI_JOB_MODEL=gpt-4.1-mini

# Jobs sync policy
JOB_ACTIVE_LIMIT_PER_SOURCE=300
JOB_ACTIVE_SOURCES=saramin,wanted

# Google Calendar OAuth
GOOGLE_CALENDAR_CLIENT_ID=...
GOOGLE_CALENDAR_CLIENT_SECRET=...
GOOGLE_CALENDAR_REDIRECT_URI=https://your-domain.com/planner/google/callback/
